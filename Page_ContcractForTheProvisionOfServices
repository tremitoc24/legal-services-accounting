# Область СистемныеОбработчики
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Элементы.Итого.Видимость = Ложь;
	Элементы.Скидка.Видимость = Ложь;
	Элементы.НадбавкаЗаСрочность.Видимость = Ложь;
КонецПроцедуры
&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Объект.Дата = ТекущаяДата();
КонецПроцедуры
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОбновитьИтог()
КонецПроцедуры
# КонецОбласти

# Область ОбработчикиФормы
&НаКлиенте
Процедура ТЧУслугиУслугаПриИзменении(Элемент)
	СтрокаТЧ = Элементы.ТЧУслуги.ТекущаяСтрока;
	Если СтрокаТЧ = Неопределено Тогда
		Сообщить("Ошибка: Текущая строка не найдена");
		Возврат;
	КонецЕсли;
	Попытка
		Услуга = Объект.ТЧУслуги[СтрокаТЧ].Услуга;
		Если Услуга = Неопределено Тогда
			Сообщить("Ошибка: Данная услуга не найдена");
			Возврат;
		Иначе
			СтоимостьУслуги = РаботаСДАнны-ми.ВернутьСтоимостьУслуги(Услуга);
			Объект.ТЧУслуги[СтрокаТЧ].СтоимостьУслуги = СтоимостьУслуги;
		КонецЕсли;
		ОбновитьИтог();
	Исключение
		Сообщить("Ошибка: Произошла ошибка при вычислении стоимости услуги");
		Возврат;
	КонецПопытки;
КонецПроцедуры
# КонецОбласти

# Область ПроцедурыФункционал
&НаКлиенте
Процедура ОбновитьИтог() Экспорт
	ИтоговаяСтоимость = 0;
	Для Каждого СтрокаТЧ Из Объект.ТЧУслуги Цикл
		ИтоговаяСтоимость = ИтоговаяСтоимость + СтрокаТЧ.СтоимостьУслуги;
	КонецЦикла; 
	Элементы.Итого.Видимость = Истина;
	Если Объект.НадбавкаЗаСрочность <> 0 Тогда
		Элементы.НадбавкаЗаСрочность.Видимость = Истина;
	КонецЕсли;
	Если Объект.СкидкаКлиента <> 0 Тогда
		Элементы.Скидка.Видимость = Истина;
	КонецЕсли;
	Объект.Итого = РаботаСДанны-ми.ВернутьСтоимостьСУчетомНадбвакиИСкидки(
		ИтоговаяСтоимость, Объект.НадбавкаЗаСрочность, Объект.СкидкаКлиента);
КонецПроцедуры
# КонецОбласти
