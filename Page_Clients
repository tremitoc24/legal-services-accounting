# Область СистемныеОбработчики
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОтобразитьГруппыРеквизитов();
КонецПроцедуры 
&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.ВидКлиента = РаботаСДанны-ми.ВернутьВидКлиента("ФизическоеЛицо") Тогда
		Если Объект.ФамилияКлиента = Неопределено ИЛИ Объект.ИмяКлиента = Неопределено Тогда
			Сообщить("Клиент не может быть создан: Необходимо указать Фами-лию и Имя.");
			Возврат;
		КонецЕсли;
		ИзменитьНаименование(Объект.ФамилияКлиента, Объект.ИмяКлиента, Объ-ект.ОтчествоКлиента);
		Если Объект.СтатусКлиента = РаботаСДанны-ми.ВернутьСтатусКлиента("Организация") Тогда
			Сообщить("Статус клиента с видом Физическое лицо не может иметь статус Организация");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	Если Объект.ВидКлиента = РаботаСДанны-ми.ВернутьВидКлиента("ЮридическоеЛицо") Тогда
		Если Объект.НазваниеОрганизации = Неопределено Тогда
			Сообщить("Клиент не может быть создан: Необходимо указать название организации.");
			Возврат;
	    КонецЕсли;
		ИзменитьНаименование(,,, Объект.НазваниеОрганизации);
		Если Объект.СтатусКлиента <> РаботаСДанны-ми.ВернутьСтатусКлиента("Организация") Тогда
			Сообщить("Статус клиента с видом Юридическое лицо может иметь только статус Организация");
			Возврат;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
# КонецОбласти

# Область ОбработчикиФормы
&НаКлиенте
Процедура ВидКлиентаПриИзменении(Элемент)
	ИзменитьНаименование();
	ОтобразитьГруппыРеквизитов();
	Если Объект.ВидКлиента = РаботаСДанны-ми.ВернутьВидКлиента("ЮридическоеЛицо") Тогда
		Объект.СтатусКлиента = РаботаСДанны-ми.ВернутьСтатусКлиента("Организация");
	Иначе
		Объект.СтатусКлиента = РаботаСДанными.ВернутьСтатусКлиента("Нет");
	КонецЕсли;
КонецПроцедуры 
&НаСервере
Процедура ОтобразитьГруппыРеквизитов()
	Если Объект.ВидКлиента = РаботаСДанны-ми.ВернутьВидКлиента("ФизическоеЛицо") Тогда
		Элементы.ГруппаРеквизитыФизЛица.Видимость = Истина;
		Элементы.ГруппаРеквизитыЮрЛица.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	Если Объект.ВидКлиента = РаботаСДанны-ми.ВернутьВидКлиента("ЮридическоеЛицо") Тогда 
		Элементы.ГруппаРеквизитыФизЛица.Видимость = Ложь;
		Элементы.ГруппаРеквизитыЮрЛица.Видимость = Истина;
		Возврат;
	КонецЕсли;
	Если Объект.ВидКлиента <> РаботаСДанны-ми.ВернутьВидКлиента("ЮридическоеЛицо") 
		И Объект.ВидКлиента <> РаботаСДанны-ми.ВернутьВидКлиента("ФизическоеЛицо") Тогда
		Элементы.ГруппаРеквизитыФизЛица.Видимость = Ложь;
		Элементы.ГруппаРеквизитыЮрЛица.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры
# КонецОбласти

# Область ПроцедурыФункционал
&НаКлиенте
Процедура ИзменитьНаименование(
	Фамилия = Неопределено,
	Имя = Неопределено,
	Отчество = Неопределено,
	НаименованиеОрганизации = Неопределено) Экспорт
	Если НаименованиеОрганизации <> Неопределено Тогда
		Объект.Наименование = НаименованиеОрганизации;
		Возврат;
	КонецЕсли;
	Если Фамилия <> Неопределено И Имя <> Неопределено Тогда  
		Наименование = СтрШаблон("%1 %2.", Фамилия, Лев(Имя, 1));
		Если Отчество <> Неопределено Тогда
			Наименование = СтрШаблон("%1%2.", Наименование, Лев(Отчество, 1));
		КонецЕсли;
		Объект.Наименование = Наименование;
	Иначе
		Объект.Наименование = "";
	КонецЕсли;
КонецПроцедуры
# КонецОбласти
