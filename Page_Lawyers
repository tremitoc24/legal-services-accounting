# Область СистемныеОбработчики
&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.ФамилияЮриста = Неопределено ИЛИ Объект.ИмяЮриста = Не-определено Тогда
        Сообщить("Юрист не может быть зарегистрирован в системе: Необходимо указать Фамилию и Имя.");
		Возврат;
	КонецЕсли;
	Попытка
		ИзменитьНаименование(Объект.ФамилияЮриста, Объект.ИмяЮриста, Объ-ект.ОтчествоЮриста);
	Исключение
		Сообщить("Произошла ошибка");
	КонецПопытки;
КонецПроцедуры
# КонецОбласти

# Область ПроцедурыФункционал
&НаКлиенте
Процедура ИзменитьНаименование(Фамилия, Имя, Отчество = Неопределено) Экс-порт
	Наименование = СтрШаблон("%1 %2.", Фамилия, Лев(Имя, 1));
	Если Отчество <> Неопределено Тогда
		Наименование = СтрШаблон("%1%2.", Наименование, Лев(Отчество, 1));
	КонецЕсли;
	Объект.Наименование = Наименование;
КонецПроцедуры
# КонецОбласти
