# Область ПроцедурыПечати
&НаСервере
Процедура ПлатежиПечать(ТабДок, Ссылка) Экспорт
	Макет = Документы.Платежи.ПолучитьМакет("ПлатежиПечать");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Платежи.Номер КАК Номер,
	|	Платежи.Дата КАК Дата,
	|	Платежи.Договор КАК Договор,
	|	Платежи.Клиент КАК Клиент,
	|	Платежи.СпособОплаты КАК СпособОплаты,
	|	Платежи.НадбавкаЗаСрочность КАК Надбавка,
	|	Платежи.СкидкаКлиента КАК Скидка,
	|	Платежи.Итого КАК Итого,
	|	Платежи.ТЧУслуги.(
	|		НомерСтроки КАК НомерСтроки,
	|		Услуга КАК Услуга,
	|		Платежи.ТЧУслуги.СтоимостьУслуги КАК СтоимостьУслуги
	|	) КАК ТЧУслуги,
	|	Платежи.Клиент.ВидКлиента КАК КлиентВидКлиента,
	|	Платежи.Клиент.НомерТелефонаКлиента КАК КлиентНомерТелефонаКлиен-та,
	|	Платежи.Клиент.АдресПочтыКлиента КАК КлиентАдресПочтыКлиента,
	|	Платежи.Клиент.ДатаРождения КАК КлиентДатаРождения,
	|	Платежи.Клиент.РегионПроживания КАК КлиентРегионПроживания,
	|	Платежи.Клиент.АдресПроживания КАК КлиентАдресПроживания,
	|	Платежи.Клиент.ФамилияКонтактногоЛица КАК КлиентФамилияКонтактно-гоЛица,
	|	Платежи.Клиент.ИмяКонтактногоЛица КАК КлиентИмяКонтактногоЛица,
	|	Платежи.Клиент.ОтчествоКонтактногоЛица КАК КлиентОтчествоКонтактно-гоЛица,
	|	Платежи.Клиент.ИНН КАК КлиентИНН,
	|	Платежи.Клиент.ОГРН КАК КлиентОГРН,
	|	Платежи.Клиент.ЮридическийАдрес КАК КлиентЮридическийАдрес,
	|	Платежи.Юрист КАК Юрист
	|ИЗ
	|	Документ.Платежи КАК Платежи
	|ГДЕ
	|	Платежи.Ссылка В(&Ссылка)";
	Запрос.Параметры.Вставить("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Заголовок = Макет.ПолучитьОбласть("Заголовок");
	Шапка = Макет.ПолучитьОбласть("Шапка");
	СоставДоговораШапка = Макет.ПолучитьОбласть("СоставДоговораШапка");
	СоставДоговораТело = Макет.ПолучитьОбласть("СоставДоговораТело");
	ИтогоРазделитель = Макет.ПолучитьОбласть("ИтогоРазделитель");
	Надбавка = Макет.ПолучитьОбласть("Надбавка");
	Скидка = Макет.ПолучитьОбласть("Скидка");
	Подвал = Макет.ПолучитьОбласть("Подвал");
	ПодписиСторон = Макет.ПолучитьОбласть("ПодписиСторон");
    ТабДок.Очистить();
	Пока Выборка.Следующий() Цикл
		Заголовок.Параметры.Заполнить(Выборка);
		ТабДок.Вывести(Заголовок);
		Шапка.Параметры.НаименованиеОрганизации = Констан-ты.НаименованиеОрганизации.Получить();
		ДанныеОрганизации = Констан-ты.ЮридическийАдресОрганизации.Получить() + ", " +
			"ОГРН: " + Константы.ОГРНОрганизации.Получить() + ", " +
			"ИНН: " + Константы.ИННОрганизации.Получить() + ", " +
			"Телефон: " + Константы.ТелефонОрганизации.Получить() + ", " +
			"Почта: " + Константы.АдресПочтыОрганизации.Получить() +
			", в лице " + Выборка.Юрист + ", действующего на основании устава.";
		Шапка.Параметры.ДанныеОрганизации = ДанныеОрганизации;
		Шапка.Параметры.Клиент = Выборка.Клиент;
		Если Выборка.КлиентВидКлиента = Перечисле-ния.ВидыКлиентов.ЮридическоеЛицо Тогда
			ДанныеКлиента = Выборка.КлиентЮридическийАдрес + ", " +
				"ОГРН: " + Выборка.КлиентОГРН + ", " +
				"ИНН: " + Выборка.КлиентИНН + ", " +
				"Телефон: " + Выборка.КлиентНомерТелефонаКлиента + ", " +
				"Почта: " + Выборка.КлиентАдресПочтыКлиента +
				", в лице " + РаботаСДанны-ми.ВернутьФИОКонактногоЛицаКлиента(
					Выборка.КлиентФамилияКонтактногоЛица,
					Выборка.КлиентИмяКонтактногоЛица,
					Выборка.КлиентОтчествоКонтактногоЛица);
			Шапка.Параметры.ДанныеКлиента = ДанныеКлиента;
		КонецЕсли;
		Если Выборка.КлиентВидКлиента = Перечисле-ния.ВидыКлиентов.ФизическоеЛицо Тогда
			ДанныеКлиента = "Дата рождения: " + Выборка.КлиентДатаРождения + ", " +
				"Телефон: " + Выборка.КлиентНомерТелефонаКлиента + ", " +
				"Почта: " + Выборка.КлиентАдресПочтыКлиента + ", " +
				"Адрес: " + Выборка.КлиентРегионПроживания + " " +
				Выборка.КлиентАдресПроживания;
			Шапка.Параметры.ДанныеКлиента = ДанныеКлиента;
		КонецЕсли;
		Шапка.Параметры.Договор = Выборка.Договор;
		Шапка.Параметры.СпособОплаты = Выборка.СпособОплаты;
		ТабДок.Вывести(Шапка);
		ТабДок.Вывести(СоставДоговораШапка);
		КоличествоУслуг = 0;
		ВыборкаТЧУслуги = Выборка.ТЧУслуги.Выбрать();		
		Пока ВыборкаТЧУслуги.Следующий() Цикл
			КоличествоУслуг = КоличествоУслуг + 1;
			СоставДоговораТело.Параметры.Заполнить(ВыборкаТЧУслуги);
			ТабДок.Вывести(СоставДоговораТело, ВыборкаТЧУслуги.Уровень());
		КонецЦикла;
		ТабДок.Вывести(ИтогоРазделитель);
		Если Выборка.Надбавка <> 0 Тогда
			Надбавка.Параметры.Заполнить(Выборка);
			ТабДок.Вывести(Надбавка);
		КонецЕсли;
		Если Выборка.Скидка <> 0 Тогда
			Скидка.Параметры.Заполнить(Выборка);
			ТабДок.Вывести(Скидка);
		КонецЕсли;
		Подвал.Параметры.Итого = Выборка.Итого;
		Подвал.Параметры.КоличествоУслуг = КоличествоУслуг;
		Подвал.Параметры.ИтогоПрописью =
				ЧислоПрописью(Выборка.Итого, "Л = ru_RU; ДП = Истина", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
		ТабДок.Вывести(Подвал);
		ПодписиСторон.Параметры.Заполнить(Выборка);
		ТабДок.Вывести(ПодписиСторон);
	КонецЦикла;
КонецПроцедуры
# КонецОбласти
