# Область ФункцииВозвратаЗначений
&НаСервере
Функция ВернутьСтоимостьУслуги(Услуга) Экспорт
	Возврат Услуга.Стоимость;	
КонецФункции
&НаСервере
Функция ВернутьСкидкуКлиента(Клиент) Экспорт
	Возврат Клиент.СтатусКлиента.ПроцентСкидки;
КонецФункции
&НаСервере
Функция ВернутьПрибавкуКСтоимостиЗаСрочность(Срочность) Экспорт
	Возврат Срочность.НадбавкаКСтоимости;
КонецФункции
&НаСервере
Функция ВернутьВидКлиента(Вид) Экспорт
	Возврат ПредопределенноеЗначе-ние(СтрШаблон("Перечисление.ВидыКлиентов.%1", Вид));
КонецФункции 
&НаСервере
Функция ВернутьСтатусКлиента(Статус) Экспорт
	Если Статус = "Нет" Тогда
		Возврат Справочники.СтатусыКлиентов.ПустаяСсылка();
	КонецЕсли;
	Возврат Справочники.СтатусыКлиентов.НайтиПоНаименованию(Статус);
КонецФункции
&НаСервере
Функция ВернутьСтатусДоговора(Договор) Экспорт
	Возврат Договор.СтатусДоговора;
КонецФункции
# КонецОбласти

# Область ФункцииРасчетаЗначений
&НаСервере
Функция ВернутьСтоимостьСУчетомНадбвакиИСкидки(Сумма, Надбавка, Скидка) Экспорт
	Если Надбавка <> 0 Тогда
		Сумма = Сумма + (Сумма * Надбавка / 100);
	КонецЕсли;
	Если Скидка <> 0 Тогда
		Сумма = Сумма - (Сумма * Скидка / 100);
	КонецЕсли;
	Возврат Сумма;
КонецФункции
&НаСервере
Функция ВернутьФИОКонактногоЛицаКлиента(Фамилия, Имя, Отчество = Неопреде-лено) Экспорт
	Если Отчество <> Неопределено Тогда
		Возврат СтрШаблон("%1 %2.%3.", Фамилия, ЛЕВ(Имя, 1), ЛЕВ(Отчество, 1));
	Иначе
		Возврат СтрШаблон("%1 %2.", Фамилия, ЛЕВ(Имя, 1));
	КонецЕсли;
КонецФункции
# КонецОбласти
