# Область ОбработкиИнтерфейса
&НаКлиенте
Процедура АктивныйЮристПриИзменении(Элемент)
	ОбновитьТаблицы();
КонецПроцедуры
&НаКлиенте
Процедура ОтображениеСкрытыхДоговоровПриИзменении(Элемент)
	Если ОтображениеСкрытыхДоговоров = Истина Тогда
		Элементы.ГруппаСтатусПриостановлен.Видимость = Истина;
		Элементы.ГруппаСтатусРасторгнут.Видимость = Истина;
	КонецЕсли;  
	Если ОтображениеСкрытыхДоговоров = Ложь Тогда
		Элементы.ГруппаСтатусПриостановлен.Видимость = Ложь;
		Элементы.ГруппаСтатусРасторгнут.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура ОбновитьОтображениеТаблиц(Команда)
	ОбновитьТаблицы()
КонецПроцедуры
# КонецОбласти

# Область ПроцедурыПередвижениеДоговоровНаСервере
&НаСервере
Функция ВернутьЗначениеСтатуса(Статус)
	Если Статус = "Подписан" Тогда
		Возврат Перечисления.СтатусыДоговоров.Подписан;
	ИначеЕсли Статус = "ВПроцессе" Тогда
		Возврат Перечисления.СтатусыДоговоров.ВПроцессеИсполнения;
	ИначеЕсли Статус = "Завершён" Тогда
		Возврат Перечисления.СтатусыДоговоров.Завершён;
	ИначеЕсли Статус = "Приостановлен" Тогда
		Возврат Перечисления.СтатусыДоговоров.Приостановлен;
	ИначеЕсли Статус = "Расторгнут" Тогда
		Возврат Перечисления.СтатусыДоговоров.Расторгнут;
	КонецЕсли;
КонецФункции
&НаСервере
Процедура ЗаполнитьТаблицу(СтатусДоговора, Юрист)
	Перем Таблица;
	Если СтатусДоговора = Перечисления.СтатусыДоговоров.Подписан Тогда
		Таблица = ТаблицаСтатусПодписан;
	ИначеЕсли СтатусДоговора = Перечисле-ния.СтатусыДоговоров.ВПроцессеИсполнения Тогда
		Таблица = ТаблицаСтатусВПроцессе;
	ИначеЕсли СтатусДоговора = Перечисления.СтатусыДоговоров.Завершён Тогда
		Таблица = ТаблицаСтатусЗавершен;
	ИначеЕсли СтатусДоговора = Перечисления.СтатусыДоговоров.Приостановлен Тогда
		Таблица = ТаблицаСтатусПриостановлен;
	ИначеЕсли СтатусДоговора = Перечисления.СтатусыДоговоров.Расторгнут То-гда
		Таблица = ТаблицаСтатусРасторгнут;
	КонецЕсли;
	Таблица.Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РНРегистрИзмененияСтатусаДоговора.Договор КАК Договор,
		|	РНРегистрИзмененияСтатусаДоговора.ДатаПодписанияДоговора КАК ДатаПодписанияДоговора,
		|	РНРегистрИзмененияСтатусаДоговора.Период КАК Период
		|ИЗ
		|	РегистрНакопления.РНРегистрИзмененияСтатусаДоговора КАК РНРе-гистрИзмененияСтатусаДоговора
		|ГДЕ
		|	РНРегистрИзмененияСтатусаДоговора.Юрист = &Юрист
		|	И РНРегистрИзмененияСтатусаДоговора.СтатусДоговора = &СтатусДоговора";
	Запрос.УстановитьПараметр("СтатусДоговора", СтатусДоговора);
	Запрос.УстановитьПараметр("Юрист", Юрист);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаДоговора = Таблица.Добавить();
		СтрокаДоговора.Договор = Выборка.Договор;
		СтрокаДоговора.ДатаПодписания = Выборка.ДатаПодписанияДоговора;
		Если Таблица <> ТаблицаСтатусПодписан Тогда
			СтрокаДоговора.ДатаИзменения = Выборка.Период;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
&НаКлиенте
Процедура ОбновитьТаблицы()
	ЗаполнитьТаблицу(ВернутьЗначениеСтатуса("Подписан"), АктивныйЮрист);
	ЗаполнитьТаблицу(ВернутьЗначениеСтатуса("ВПроцессе"), АктивныйЮрист);
	ЗаполнитьТаблицу(ВернутьЗначениеСтатуса("Завершён"), АктивныйЮрист);
	ЗаполнитьТаблицу(ВернутьЗначениеСтатуса("Приостановлен"), Активный-Юрист);
	ЗаполнитьТаблицу(ВернутьЗначениеСтатуса("Расторгнут"), АктивныйЮрист);
КонецПроцедуры
&НаСервере
Процедура ПередвижениеДоговораНаСервере(Договор, НовыйСтатус)
	ДоговорОбъект = Договор.ПолучитьОбъект();
	ДоговорОбъект.СтатусДоговора = НовыйСтатус;
	ДоговорОбъект.ЗаписьВРегистрНакопденийСтатусаДоговора(
		НовыйСтатус,
		ДоговорОбъект.Оплачен);
	ДоговорОбъект.Записать();	
КонецПроцедуры
&НаКлиенте
Процедура ПередвижениеДоговора(Статус, НовыйСтатус)
	Попытка
		Если Статус = ВернутьЗначениеСтатуса("Подписан") Тогда
			ДанныеДоговора = Элемен-ты.ТаблицаСтатусПодписан.ТекущиеДанные.Договор;
		ИначеЕсли Статус = ВернутьЗначениеСтатуса("ВПроцессе") Тогда
			ДанныеДоговора = Элемен-ты.ТаблицаСтатусВПроцессе.ТекущиеДанные.Договор;
		ИначеЕсли Статус = ВернутьЗначениеСтатуса("Приостановлен") Тогда
			ДанныеДоговора = Элемен-ты.ТаблицаСтатусПриостановлен.ТекущиеДанные.Договор;
		КонецЕсли;		
		ПередвижениеДоговораНаСервере(ДанныеДоговора, НовыйСтатус);
		ЗаполнитьТаблицу(Статус, АктивныйЮрист);
		ЗаполнитьТаблицу(НовыйСтатус, АктивныйЮрист);
	Исключение
		Сообщить("Произошла ошибка!");
		Возврат;
	КонецПопытки
КонецПроцедуры
# КонецОбласти

