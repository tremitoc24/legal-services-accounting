# Область ПроцедурыПечати
&НаСервере
Процедура ПечатьДокумента(ТабДок, Ссылка) Экспорт
	Макет = Докумен-ты.ДоговорыНаОказаниеУслуг.ПолучитьМакет("ПечатьДокумента");
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДоговорыНаОказаниеУслуг.Номер КАК Номер,
	|	ДоговорыНаОказаниеУслуг.Клиент КАК Клиент,
	|	ДоговорыНаОказаниеУслуг.Юрист КАК Юрист,
	|	ДоговорыНаОказаниеУслуг.Итого КАК Итого,
	|	ДоговорыНаОказаниеУслуг.ТЧУслуги.(
	|		Услуга КАК Услуга,
	|		ДатаПроведенияУслуги КАК ДатаПроведенияУслуги
	|	) КАК ТЧУслуги,
	|	ДЕНЬ(ДоговорыНаОказаниеУслуг.Дата) КАК ДатаДень,
	|	МЕСЯЦ(ДоговорыНаОказаниеУслуг.Дата) КАК ДатаМесяц,
	|	ГОД(ДоговорыНаОказаниеУслуг.Дата) КАК ДатаГод,
	|	ДоговорыНаОказаниеУслуг.Клиент.ВидКлиента КАК КлиентВидКлиента,
	|	ДоговорыНаОказаниеУслуг.Клиент.НомерТелефонаКлиента КАК КлиентНо-мерТелефонаКлиента,
	|	ДоговорыНаОказаниеУслуг.Клиент.АдресПочтыКлиента КАК КлиентАдре-сПочтыКлиента,
	|	ДоговорыНаОказаниеУслуг.Клиент.ИНН КАК КлиентИНН,
	|	ДоговорыНаОказаниеУслуг.Клиент.ОГРН КАК КлиентОГРН,
	|	ДоговорыНаОказаниеУслуг.Клиент.ЮридическийАдрес КАК КлиентЮриди-ческийАдрес,
	|	ДоговорыНаОказаниеУслуг.Клиент.ФамилияКонтактногоЛица КАК Клиент-ФамилияКонтактногоЛица,
	|	ДоговорыНаОказаниеУслуг.Клиент.ИмяКонтактногоЛица КАК КлиентИмя-КонтактногоЛица,
	|	ДоговорыНаОказаниеУслуг.Клиент.ОтчествоКонтактногоЛица КАК Клиен-тОтчествоКонтактногоЛица,
	|	ДоговорыНаОказаниеУслуг.Клиент.АдресПроживания КАК КлиентАдре-сПроживания,
	|	ДоговорыНаОказаниеУслуг.Клиент.РегионПроживания КАК КлиентРегион-Проживания,
	|	ДоговорыНаОказаниеУслуг.Клиент.ДатаРождения КАК ДатаРождения
	|ИЗ
	|	Документ.ДоговорыНаОказаниеУслуг КАК ДоговорыНаОказаниеУслуг
	|ГДЕ
	|	ДоговорыНаОказаниеУслуг.Ссылка В(&Ссылка)";
	Запрос.Параметры.Вставить("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Заголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбщиеПоложенияОрганизация = Ма-кет.ПолучитьОбласть("ОбщиеПоложенияОрганизация");
	ОбщиеПоложенияКлиентОрганизация = Ма-кет.ПолучитьОбласть("ОбщиеПоложенияКлиентОрганизация");
	ОбщиеПоложенияКлиентФизЛицо = Ма-кет.ПолучитьОбласть("ОбщиеПоложенияКлиентФизЛицо");
	ПредметДоговора1_1 = Макет.ПолучитьОбласть("ПредметДоговора1_1");
	ПредметДоговораСоставУслуг = Ма-кет.ПолучитьОбласть("ПредметДоговораСоставУслуг");
	ПредметДоговора1_2 = Макет.ПолучитьОбласть("ПредметДоговора1_2");
	ПраваИОбязанности = Макет.ПолучитьОбласть("ПраваИОбязанности");
	Стоимость = Макет.ПолучитьОбласть("Стоимость");
	Ответственность = Макет.ПолучитьОбласть("Ответственность");
	Конфиденциальность = Макет.ПолучитьОбласть("Конфиденциальность");
	ПрочиеУсловия = Макет.ПолучитьОбласть("ПрочиеУсловия");
	РеквизитыКлиентОрганизация = Ма-кет.ПолучитьОбласть("РеквизитыКлиентОрганизация");
	РеквизитыКлиентФизЛицо = Ма-кет.ПолучитьОбласть("РеквизитыКлиентФизЛицо");
	ПодписиСторон = Макет.ПолучитьОбласть("ПодписиСторон");
	ТабДок.Очистить();
	Пока Выборка.Следующий() Цикл
		Заголовок.Параметры.Заполнить(Выборка);
		ТабДок.Вывести(Заголовок);
		ОбщиеПоложенияОрганизация.Параметры.НаименованиеОрганизации = Кон-станты.НаименованиеОрганизации.Получить();
		ОбщиеПоложенияОрганизация.Параметры.Юрист = Выборка.Юрист;
		ТабДок.Вывести(ОбщиеПоложенияОрганизация);
		Если Выборка.КлиентВидКлиента = Перечисле-ния.ВидыКлиентов.ЮридическоеЛицо Тогда
			ОбщиеПоложенияКлиентОрганизация.Параметры.Клиент = Выбор-ка.Клиент;
			ОбщиеПоложенияКлиентОрганизация.Параметры.КонтактноеЛицо = 
				РаботаСДанными.ВернутьФИОКонактногоЛицаКлиента(
					Выборка.КлиентФамилияКонтактногоЛица,
					Выборка.КлиентИмяКонтактногоЛица,
					Выборка.КлиентОтчествоКонтактногоЛица);
			ТабДок.Вывести(ОбщиеПоложенияКлиентОрганизация);
		КонецЕсли;
		Если Выборка.КлиентВидКлиента = Перечисле-ния.ВидыКлиентов.ФизическоеЛицо Тогда
			ОбщиеПоложенияКлиентФизЛицо.Параметры.Заполнить(Выборка);
			ТабДок.Вывести(ОбщиеПоложенияКлиентФизЛицо);
		КонецЕсли;
		ТабДок.Вывести(ПредметДоговора1_1);
		ВыборкаТЧУслуги = Выборка.ТЧУслуги.Выбрать();		
		Пока ВыборкаТЧУслуги.Следующий() Цикл
			ПредметДоговораСоста-вУслуг.Параметры.Заполнить(ВыборкаТЧУслуги);
			ТабДок.Вывести(ПредметДоговораСоставУслуг, ВыборкаТЧУслу-ги.Уровень());
		КонецЦикла;
		ТабДок.Вывести(ПредметДоговора1_2);
		ТабДок.Вывести(ПраваИОбязанности);
        Стоимость.Параметры.Итого = Выборка.Итого;
		Стоимость.Параметры.ИтогоПрописью = 
			ЧислоПрописью(Выборка.Итого, "Л = ru_RU; ДП = Истина", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
		ТабДок.Вывести(Стоимость);
		ТабДок.Вывести(Ответственность);
		ТабДок.Вывести(Конфиденциальность);
		ТабДок.Вывести(ПрочиеУсловия);
		Если Выборка.КлиентВидКлиента = Перечисле-ния.ВидыКлиентов.ЮридическоеЛицо Тогда
			РеквизитыКлиентОрганизация.Параметры.ЮрАдресОрганизации = Константы.ЮридическийАдресОрганизации.Получить();
			РеквизитыКлиентОрганизация.Параметры.ТелефонОрганизации = Кон-станты.ТелефонОрганизации.Получить();
			РеквизитыКлиентОрганизация.Параметры.АдресПочтыОрганизации = Константы.АдресПочтыОрганизации.Получить();
			РеквизитыКлиентОрганизация.Параметры.ИННОрганизации = Кон-станты.ИННОрганизации.Получить();
			РеквизитыКлиентОрганизация.Параметры.ОГРНОрганизации = Кон-станты.ОГРНОрганизации.Получить();
			РеквизитыКлиентОрганизация.Параметры.ЮрАдресКлиента = Выбор-ка.КлиентЮридическийАдрес;
			РеквизитыКлиентОрганизация.Параметры.ТелефонКлиента = Выбор-ка.КлиентНомерТелефонаКлиента;
			РеквизитыКлиентОрганизация.Параметры.АдресПочтыКлиента = Вы-борка.КлиентАдресПочтыКлиента;
			РеквизитыКлиентОрганизация.Параметры.ИННКлиента = Выбор-ка.КлиентИНН;
			РеквизитыКлиентОрганизация.Параметры.ОГРНКлиента = Выбор-ка.КлиентОГРН;
			ТабДок.Вывести(РеквизитыКлиентОрганизация);
		КонецЕсли;
		Если Выборка.КлиентВидКлиента = Перечисле-ния.ВидыКлиентов.ФизическоеЛицо Тогда
			РеквизитыКлиентФизЛицо.Параметры.ЮрАдресОрганизации = Кон-станты.ЮридическийАдресОрганизации.Получить();
			РеквизитыКлиентФизЛицо.Параметры.ТелефонОрганизации = Кон-станты.ТелефонОрганизации.Получить();
			РеквизитыКлиентФизЛицо.Параметры.АдресПочтыОрганизации = Константы.АдресПочтыОрганизации.Получить();
			РеквизитыКлиентФизЛицо.Параметры.ИННОрганизации = Констан-ты.ИННОрганизации.Получить();
			РеквизитыКлиентФизЛицо.Параметры.ОГРНОрганизации = Констан-ты.ОГРНОрганизации.Получить();
			РеквизитыКлиентФизЛицо.Параметры.ТелефонКлиента = Выбор-ка.КлиентНомерТелефонаКлиента;
			РеквизитыКлиентФизЛицо.Параметры.АдресПочтыКлиента = Выбор-ка.КлиентАдресПочтыКлиента;
			РеквизитыКлиентФизЛицо.Параметры.РегионПроживания = Выбор-ка.КлиентРегионПроживания;
			РеквизитыКлиентФизЛицо.Параметры.АдресПроживания = Выбор-ка.КлиентАдресПроживания;
			ТабДок.Вывести(РеквизитыКлиентФизЛицо);
		КонецЕсли;
		ТабДок.Вывести(ПодписиСторон);
	КонецЦикла;
КонецПроцедуры
# КонецОбласти
